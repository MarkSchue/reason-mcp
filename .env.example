# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed as a reference.

# ── ArangoDB connection ────────────────────────────────────────────────────────
REASON_ARANGO_URL=http://localhost:8529
REASON_ARANGO_USER=root
REASON_ARANGO_PASSWORD=
# Rules database name
REASON_ARANGO_DB=reason
# Override only if you need non-default collection names in the rules DB:
# REASON_ARANGO_RULES_COLL=rules
# REASON_ARANGO_EDGES_COLL=rule_relations

# ── Praxis graph database ──────────────────────────────────────────────────────
REASON_PRAXIS_DB=praxis
REASON_PRAXIS_GRAPH_NAME=praxis_graph
# Vertex collections — TypeName:collection:key_prefix  (comma-separated)
REASON_PRAXIS_VERTEX_SPECS=Worker:workers:worker_,WorkingHours:working_hours:hours_
# Edge collections — TypeName:collection:from_collection:to_collection  (comma-separated)
REASON_PRAXIS_EDGE_SPECS=arbeitet:arbeitet:workers:working_hours,vertritt:vertritt:workers:workers

# ── Retrieval tuning ───────────────────────────────────────────────────────────
REASON_DEFAULT_TOP_K=3
REASON_MIN_RELEVANCE=0.5
REASON_MAX_SUMMARY_CHARS=900

# ── Observability ──────────────────────────────────────────────────────────────
REASON_LOG_LEVEL=INFO

# Set to 1 / true / yes to write Markdown session logs to REASON_OUTPUT_DIR
REASON_LOG_REQUESTS=0
REASON_OUTPUT_DIR=./output
