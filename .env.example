# Path to the knowledge store directory (JSON rules + facts)
# Can be overridden per project deployment
REASON_KNOWLEDGE_DIR=./knowledge

# Default top-k results injected into LLM context
REASON_DEFAULT_TOP_K=3

# Minimum relevance score for a rule to be included (0.0 - 1.0)
REASON_MIN_RELEVANCE=0.5

# Max characters in the summary_for_llm field
REASON_MAX_SUMMARY_CHARS=900

# Log level: DEBUG | INFO | WARNING | ERROR
REASON_LOG_LEVEL=INFO
