# reason-mcp — example environment configuration
# Copy this file to .env and fill in your values.
# .env is loaded automatically at server startup (via python-dotenv).
# Shell environment variables always override .env values.

# ---------------------------------------------------------------------------
# ArangoDB connection
# ---------------------------------------------------------------------------
REASON_ARANGO_URL=http://localhost:8529
REASON_ARANGO_USER=root
REASON_ARANGO_PASSWORD=changeme

# Database and collection names
REASON_ARANGO_DB=reason
REASON_ARANGO_RULES_COLL=rules
REASON_ARANGO_EDGES_COLL=rule_relations

# ---------------------------------------------------------------------------
# Retrieval defaults
# ---------------------------------------------------------------------------
REASON_DEFAULT_TOP_K=3
REASON_MIN_RELEVANCE=0.5
REASON_MAX_SUMMARY_CHARS=900

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
REASON_LOG_LEVEL=INFO

# Set to 1 to write per-request Markdown session logs to REASON_OUTPUT_DIR
REASON_LOG_REQUESTS=0
REASON_OUTPUT_DIR=./output
