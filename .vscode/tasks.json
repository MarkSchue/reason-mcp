{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "reason-mcp: Seed ArangoDB",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python ${workspaceFolder}/scripts/seed_arango.py --knowledge-dir ${workspaceFolder}/knowledge/example",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Generate embeddings for all rules and upsert them into ArangoDB. Run this after editing any rule JSON file."
    },
    {
      "label": "reason-mcp: Seed ArangoDB (dry run)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python ${workspaceFolder}/scripts/seed_arango.py --knowledge-dir ${workspaceFolder}/knowledge/example --dry-run",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Dry-run seed: generate embeddings and print what would be written, without touching ArangoDB."
    },
    {
      "label": "reason-mcp: Start Server",
      "type": "shell",
      "command": "REASON_LOG_LEVEL=INFO ${workspaceFolder}/.venv/bin/reason-mcp",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Start the reason-mcp server. ArangoDB credentials are loaded from .env."
    }
  ]
}
